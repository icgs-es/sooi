{
  auto_https off
  admin off
}

sooi.ordixcore.com {
  encode zstd gzip

  log {
    output stdout
    level INFO
  }

  respond /health "ok" 200

  handle_path /static/* {
    root * /srv/static
    file_server
  }

  handle_path /media/* {
    root * /srv/media
    file_server
  }

  handle {
    reverse_proxy sooi_web:8000
  }
}

:80 {
  encode zstd gzip

  log {
    output stdout
    level INFO
  }

  respond /health "ok" 200

  handle_path /static/* {
    root * /srv/static
    file_server
  }

  handle_path /media/* {
    root * /srv/media
    file_server
  }

  handle {
    reverse_proxy sooi_web:8000
  }
}
